# Archer mobile (Lynx) — client env contract. Copy to `.env` and fill in.
# Only PUBLIC_-prefixed vars are exposed to the client bundle (via import.meta.env).
# Use the Supabase *publishable* key here — never the secret key.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Base URL of the Archer Hono API (services/api), e.g. http://localhost:3000
PUBLIC_ARCHER_API_URL=
