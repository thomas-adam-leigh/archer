# Archer — runtime environment contract. Copy to `.env` and fill in real values.
# Real values live in Komodo (runtime secrets) and GitHub Actions (CI secrets).
# NEVER commit a real .env — it is gitignored and gitleaks-guarded.

# --- Supabase: the control plane / source of truth ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct Postgres connection (migrations + type generation against a real branch).
DATABASE_URL=

# --- services/api (Hono) ---
PORT=3000

# --- services/cli (Scout) ---
ARCHER_API_URL=http://localhost:3000
