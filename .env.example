# Archer — runtime environment contract. Copy to `.env` and fill in real values.
# Real values live in Komodo (runtime secrets) and GitHub Actions (CI secrets).
# NEVER commit a real .env — it is gitignored and gitleaks-guarded.

# --- Supabase: the control plane / source of truth ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct Postgres connection (migrations + type generation against a real branch).
DATABASE_URL=
# Remote Postgres password — used by `supabase db push` on the release rail to
# apply migrations to Supabase on merge to main (GitHub Actions secret).
SUPABASE_DB_PASSWORD=
# Optional: a Postgres (migrations + auth stub applied) for the @archer/db
# integration tests (e.g. packages/db/src/auth-bootstrap.test.ts). Unset by
# default so the no-DB CI vitest run skips them.
TEST_DATABASE_URL=

# --- services/api (Hono) ---
PORT=3000
# Control-plane shared secret (the `x-archer-secret` header). REQUIRED in production
# — the API refuses to start without it when NODE_ENV=production (fail-closed, ARC-55).
ARCHER_API_SECRET=
# Owner/admin secret (the `x-archer-admin-secret` header) for the human-decision
# `/decide` routes (account acceptance, profile/cover-letter approvals — ARC-51).
ARCHER_API_ADMIN_SECRET=
# Dev-only: `=1` opens the API without a secret when NODE_ENV!=production. NEVER set in prod.
ARCHER_API_DEV_OPEN=
# Path to the packaged Archer CLI the API spawns as a subprocess (fail-closed when unset).
ARCHER_CLI_PATH=
# Default `user` UUID when an API request omits it (cron/CLI convenience).
ARCHER_USER_ID=

# --- LLM provider (real, swappable — ARC-59/60/61) ---
# Selector: `minimax` (default) | `openrouter` (BYOK, any model) | `mock` (tests).
# The chosen provider's key is REQUIRED (fail-closed). Keys live in Supabase secrets
# and are injected into the runtime env; unset here for local `mock` runs.
LLM_PROVIDER=mock
# LLM_MODEL=                 # override the chosen provider's default model
MINIMAX_API_KEY=             # required when LLM_PROVIDER=minimax (default model MiniMax-M3)
OPENROUTER_API_KEY=          # required when LLM_PROVIDER=openrouter (default minimax/minimax-m3)

# --- services/cli (Archer CLI) ---
ARCHER_API_URL=http://localhost:3000

# --- services/scheduler ---
# SQLite file holding the schedule config + run history. Defaults to this path.
SCHEDULER_DB_PATH=services/scheduler/scheduler.db

# --- observability: daily-collect dead-man's-switch (ARC-12) ---
# Uptime Kuma Push monitor URL (heartbeat interval just over 24h). A successful
# collect pings it; if 13:00 passes with no ping, Kuma alerts. Unset = no-op.
# See infra/observability/README.md.
UPTIME_KUMA_PUSH_URL=
