# Archer — runtime environment contract. Copy to `.env` and fill in real values.
# Real values live in Komodo (runtime secrets) and GitHub Actions (CI secrets).
# NEVER commit a real .env — it is gitignored and gitleaks-guarded.

# --- Supabase: the control plane / source of truth ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct Postgres connection (migrations + type generation against a real branch).
DATABASE_URL=
# Remote Postgres password — used by `supabase db push` on the release rail to
# apply migrations to Supabase on merge to main (GitHub Actions secret).
SUPABASE_DB_PASSWORD=

# --- services/api (Hono) ---
PORT=3000

# --- services/cli (Archer CLI) ---
ARCHER_API_URL=http://localhost:3000

# --- services/scheduler ---
# SQLite file holding the schedule config + run history. Defaults to this path.
SCHEDULER_DB_PATH=services/scheduler/scheduler.db
